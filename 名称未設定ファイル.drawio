        <mxCell id="1iUaQVIFcrmoeEtcrEnY-28" parent="1iUaQVIFcrmoeEtcrEnY-24" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;align=left;" value="" vertex="1">
          <mxGeometry height="80" width="605" y="20" as="geometry" />
        </mxCell>
        <mxCell id="1iUaQVIFcrmoeEtcrEnY-29" parent="1iUaQVIFcrmoeEtcrEnY-28" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;fontFamily=Zen Kurenaido;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DZen%2BKurenaido;" value="&lt;li data-start=&quot;383&quot; data-end=&quot;399&quot;&gt;&lt;p data-start=&quot;385&quot; data-end=&quot;399&quot;&gt;・毎日遅刻せず出社している&lt;br&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・メモは一応取っている&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・報告は早くなった&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・指示された作業は最後までやろうとしている&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="80" width="305" as="geometry">
            <mxRectangle height="80" width="305" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="1iUaQVIFcrmoeEtcrEnY-30" parent="1iUaQVIFcrmoeEtcrEnY-28" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;rowspan=3;colspan=1;align=left;verticalAlign=top;fontFamily=Zen Kurenaido;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DZen%2BKurenaido;" value="&lt;li data-start=&quot;783&quot; data-end=&quot;809&quot;&gt;&lt;p data-start=&quot;785&quot; data-end=&quot;809&quot;&gt;・質問する前に「自分なりの仮説」を1つ用意する&lt;br&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・メモに「作業の目的」「背景」を書く&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・作業後に「これは何の役に立ったのか」を一言書く&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・ミスを「手順」「判断」「確認」のどこかに分類する&lt;br&gt;・環境構成図をみてしっかり理解する&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="305" as="geometry">
            <mxRectangle height="80" width="300" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="1iUaQVIFcrmoeEtcrEnY-31" parent="1iUaQVIFcrmoeEtcrEnY-24" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" value="" vertex="1">
