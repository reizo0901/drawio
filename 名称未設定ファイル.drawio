        <mxCell id="6RJjSeLH5TekpvHChaEi-6" parent="6RJjSeLH5TekpvHChaEi-5" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;fontFamily=Zen Kurenaido;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DZen%2BKurenaido;" value="&lt;li data-start=&quot;383&quot; data-end=&quot;399&quot;&gt;&lt;p data-start=&quot;385&quot; data-end=&quot;399&quot;&gt;・毎日遅刻せず出社している&lt;br&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・メモは一応取っている&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・報告は早くなった&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;・指示された作業は最後までやろうとしている&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;" vertex="1">
